/**
 * 自动检测和读取已安装工具的配置
 * 支持：Codex (OpenAI兼容API) 和 Claude (Anthropic API)
 *
 * 注意：此模块只能在服务端使用（Node.js runtime）
 */

import { readFile, access } from 'fs/promises';
import { homedir } from 'os';
import { join } from 'path';
import { existsSync, readFileSync } from 'fs';

export interface DetectedConfig {
  claude?: {
    apiKey: string;
    baseUrl: string;
    source: string;
  };
  openai?: {
    apiKey: string;
    baseUrl: string;
    source: string;
  };
}

// 检查是否在服务端环境
const isServerSide = typeof window === 'undefined';

/**
 * 检测 Codex 配置
 * 读取 ~/.codex/config.toml 和 ~/.codex/auth.json
 */
async function detectCodexConfig(): Promise<DetectedConfig['openai'] | null> {
  if (!isServerSide) {
    return null; // 客户端不执行检测
  }

  try {
    const codexDir = join(homedir(), '.codex');
    const configPath = join(codexDir, 'config.toml');
    const authPath = join(codexDir, 'auth.json');

    // 检查文件是否存在
    await access(configPath);
    await access(authPath);

    // 读取 auth.json 获取 API key
    const authContent = await readFile(authPath, 'utf-8');
    const auth = JSON.parse(authContent);
    const apiKey = auth.OPENAI_API_KEY;

    if (!apiKey) {
      return null;
    }

    // 读取 config.toml 获取 base_url
    const configContent = await readFile(configPath, 'utf-8');

    // 解析 TOML（简单提取 base_url）
    let baseUrl = 'https://api.openai.com/v1'; // 默认值

    // 查找 cliproxyapi 配置块中的 base_url
    const baseUrlMatch = configContent.match(/\[\s*model_providers\.cliproxyapi\s*\][\s\S]*?base_url\s*=\s*["']([^"']+)["']/);
    if (baseUrlMatch && baseUrlMatch[1]) {
      baseUrl = baseUrlMatch[1];
    }

    return {
      apiKey,
      baseUrl,
      source: 'codex',
    };
  } catch (error) {
    // Codex 未安装或配置不完整
    return null;
  }
}

/**
 * 检测 Claude 配置
 * 读取 ~/.claude/settings.json
 */
async function detectClaudeConfig(): Promise<DetectedConfig['claude'] | null> {
  if (!isServerSide) {
    return null; // 客户端不执行检测
  }

  try {
    const settingsPath = join(homedir(), '.claude', 'settings.json');

    // 检查文件是否存在
    await access(settingsPath);

    // 读取 settings.json
    const content = await readFile(settingsPath, 'utf-8');
    const settings = JSON.parse(content);

    const apiKey = settings.env?.ANTHROPIC_AUTH_TOKEN;
    const baseUrl = settings.env?.ANTHROPIC_BASE_URL || 'https://api.anthropic.com';

    if (!apiKey) {
      return null;
    }

    return {
      apiKey,
      baseUrl,
      source: 'claude',
    };
  } catch (error) {
    // Claude 未安装或配置不完整
    return null;
  }
}

/**
 * 自动检测所有已配置的工具
 */
export async function detectAllConfigs(): Promise<DetectedConfig> {
  const config: DetectedConfig = {};

  // 检测 Claude 配置
  const claudeConfig = await detectClaudeConfig();
  if (claudeConfig) {
    config.claude = claudeConfig;
  }

  // 检测 Codex 配置
  const codexConfig = await detectCodexConfig();
  if (codexConfig) {
    config.openai = codexConfig;
  }

  return config;
}

/**
 * 同步版本（用于服务端初始化）
 */
export function detectAllConfigsSync(): DetectedConfig {
  const config: DetectedConfig = {};

  // 检测 Claude 配置（同步）
  try {
    const settingsPath = join(homedir(), '.claude', 'settings.json');
    if (existsSync(settingsPath)) {
      const content = readFileSync(settingsPath, 'utf-8');
      const settings = JSON.parse(content);
      const apiKey = settings.env?.ANTHROPIC_AUTH_TOKEN;
      const baseUrl = settings.env?.ANTHROPIC_BASE_URL || 'https://api.anthropic.com';

      if (apiKey) {
        config.claude = {
          apiKey,
          baseUrl,
          source: 'claude',
        };
      }
    }
  } catch (error) {
    // Claude 配置读取失败
  }

  // 检测 Codex 配置（同步）
  try {
    const codexDir = join(homedir(), '.codex');
    const authPath = join(codexDir, 'auth.json');
    const configPath = join(codexDir, 'config.toml');

    if (existsSync(authPath) && existsSync(configPath)) {
      // 读取 auth.json
      const authContent = readFileSync(authPath, 'utf-8');
      const auth = JSON.parse(authContent);
      const apiKey = auth.OPENAI_API_KEY;

      if (apiKey) {
        // 读取 config.toml
        const configContent = readFileSync(configPath, 'utf-8');
        let baseUrl = 'https://api.openai.com/v1';

        const baseUrlMatch = configContent.match(/\[\s*model_providers\.cliproxyapi\s*\][\s\S]*?base_url\s*=\s*["']([^"']+)["']/);
        if (baseUrlMatch && baseUrlMatch[1]) {
          baseUrl = baseUrlMatch[1];
        }

        config.openai = {
          apiKey,
          baseUrl,
          source: 'codex',
        };
      }
    }
  } catch (error) {
    // Codex 配置读取失败
  }

  return config;
}

/**
 * 生成检测报告
 */
export function getDetectionReport(config: DetectedConfig): string {
  const lines: string[] = [];

  lines.push('🔍 自动检测到的配置：\n');

  if (config.claude) {
    lines.push('✅ Claude配置（来自 ~/.claude/settings.json）:');
    lines.push(`   Base URL: ${config.claude.baseUrl}`);
    lines.push(`   API Key: ${config.claude.apiKey.substring(0, 10)}...`);
    lines.push('');
  } else {
    lines.push('❌ Claude配置未找到');
    lines.push('');
  }

  if (config.openai) {
    lines.push('✅ OpenAI/Codex配置（来自 ~/.codex/）:');
    lines.push(`   Base URL: ${config.openai.baseUrl}`);
    lines.push(`   API Key: ${config.openai.apiKey.substring(0, 10)}...`);
    lines.push('');
  } else {
    lines.push('❌ OpenAI/Codex配置未找到');
    lines.push('');
  }

  return lines.join('\n');
}
